{
  "name": "nook",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "portless nook next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:prod": "wrangler d1 migrations apply DB --remote",
    "db:migrate:fresh": "tsx src/scripts/db-fresh.ts",
    "db:seed:local": "wrangler d1 execute DB --local --file=./src/db/seed.sql",
    "db:seed:prod": "wrangler d1 execute DB --remote --file=./src/db/seed.prod.sql",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@opennextjs/cloudflare": "^1.17.1",
    "@react-pdf/renderer": "^4.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.2.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.5",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.1.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.1.5",
    "react-hook-form": "^7.71.2",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "use-debounce": "^10.1.0",
    "zod": "^3.22.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "15.4.6",
    "portless": "^0.7.2",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.4",
    "wrangler": "^4.70.0"
  }
}
