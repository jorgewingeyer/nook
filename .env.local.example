# Development environment variables
SESSION_SECRET=a_very_secret_key_for_development_only_at_least_32_chars

# Cloudflare Turnstile public site key (client-side, inlined at build).
# Dev: the always-pass test key below. Prod: your real site key from the
# Turnstile dashboard. The widget falls back to the test key if unset.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Host of the deployed shopping-agent worker (Phase 3). When set, the storefront
# shows the AI shopping assistant. e.g. nook-shopping-agent.<account>.workers.dev
# Leave unset locally — the assistant widget hides until the agent is deployed.
# NEXT_PUBLIC_AGENT_HOST=nook-shopping-agent.<account>.workers.dev

# Host of the deployed cart-sync worker (Phase 3 — real-time cart). When set,
# tabs/devices sync the cart live over WebSocket. Leave unset locally.
# NEXT_PUBLIC_CART_SYNC_HOST=nook-cart-sync.<account>.workers.dev
