# Development environment variables
SESSION_SECRET=a_very_secret_key_for_development_only_at_least_32_chars

# Cloudflare Turnstile public site key (client-side, inlined at build).
# Dev: the always-pass test key below. Prod: your real site key from the
# Turnstile dashboard. The widget falls back to the test key if unset.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
