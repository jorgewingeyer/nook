{
  "compilerOptions": {
    "target": "es2024",
    "lib": ["esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["@cloudflare/workers-types"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["**/*.ts", "../src/lib/payments.ts", "../src/lib/db.ts", "../src/lib/mercadopago.ts", "../src/db/schema.ts"]
}
